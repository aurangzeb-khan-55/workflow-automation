# ── Shared ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (apps/api) ─────────────────────────────────────────────────
# Note: host port 5433 (not the default 5432) — this machine has a native
# PostgreSQL service already bound to 5432; see docker-compose.yml.
DATABASE_URL="postgresql://atria:atria_dev_password@localhost:5433/atria_intake?schema=public"

# ── Redis / BullMQ (apps/api) ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Auth: Clerk (apps/api + apps/web) ────────────────────────────────────
# V1 stub mode: leave these blank and AUTH_PROVIDER=stub to run without a
# real Clerk account — the stub auth provider treats the raw bearer token
# as the user's clerkUserId directly, no signature verification. Set
# AUTH_PROVIDER=clerk and fill these in to verify real Clerk session tokens.
AUTH_PROVIDER=stub
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Storage: S3 / LocalStack (apps/api) ──────────────────────────────────
# V1 stub mode points at the local LocalStack container. Swap
# STORAGE_ENDPOINT + credentials for real AWS S3 in production, no code
# changes required (see StorageProvider interface).
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=http://localhost:4566
STORAGE_REGION=us-east-1
STORAGE_BUCKET=atria-intake-dev
STORAGE_ACCESS_KEY_ID=test
STORAGE_SECRET_ACCESS_KEY=test
STORAGE_FORCE_PATH_STYLE=true
STORAGE_SIGNED_URL_TTL_SECONDS=900

# ── Email: MailHippo (apps/api) ──────────────────────────────────────────
# V1 stub mode logs emails to the console/DB instead of sending. Set
# EMAIL_PROVIDER=mailhippo and fill in credentials to go live.
EMAIL_PROVIDER=stub
MAILHIPPO_API_KEY=
MAILHIPPO_FROM_ADDRESS=intake@atriawellness.com

# TEMPORARY: Gmail SMTP testing provider (EMAIL_PROVIDER=gmail) — a
# throwaway option for sending real test emails while MailHippo API access
# is being confirmed. Remove this block (and the provider itself) once
# MailHippo is verified; switching back is just EMAIL_PROVIDER=mailhippo.
# GMAIL_APP_PASSWORD is a Gmail App Password (not your normal password) —
# generate one under your Google Account's security settings.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── AI: Claude (apps/api) ─────────────────────────────────────────────────
# Optional module. V1 default is db_generated summaries with no external
# calls. Set AI_PROVIDER=anthropic and supply a key to enable AI summaries.
AI_PROVIDER=db_generated
ANTHROPIC_API_KEY=

# ── App URLs ──────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
INTAKE_LINK_BASE_URL=http://localhost:3000/intake

# ── Frontend (apps/web) ───────────────────────────────────────────────────
# apps/web needs its own copy of CLERK_SECRET_KEY too (Next.js middleware
# calls Clerk's backend API directly) — same Clerk app/keys as above.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
